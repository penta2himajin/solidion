---
interface Props {
  src: string;
  title: string;
  width?: number;
  height?: number;
}

const { src, title, width = 640, height = 480 } = Astro.props;
---

<div class="game-demo" style={`aspect-ratio: ${width} / ${height}`} data-game-src={src}>
  <iframe src={src} title={`${title} - Solidion Demo`} loading="lazy"></iframe>
  <a class="game-demo-overlay" href={src} target="_blank" rel="noopener">
    <span class="game-demo-play">&#9654; {title}</span>
  </a>
</div>
