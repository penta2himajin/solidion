---
const locale = Astro.currentLocale ?? "en";

const i18n: Record<string, { title: string; description: string }[]> = {
  en: [
    {
      title: "Declarative JSX",
      description:
        "Write Phaser GameObjects directly in JSX. Manipulate Phaser objects without a virtual DOM.",
    },
    {
      title: "Fine-Grained Reactivity",
      description:
        "Manage game state with SolidJS Signals. Only update what's needed — zero unnecessary re-renders.",
    },
    {
      title: "Progressive Disclosure",
      description:
        "L0(JSX) → L1(hooks) → L2(resources) → L3(frame) → L4(raw Phaser). Gradually drop to lower-level APIs as needed.",
    },
    {
      title: "Rich Hooks & Behaviors",
      description:
        "Hooks like useTween, useSpring, useStateMachine and declarative behaviors like Spring and Oscillate.",
    },
    {
      title: "Scene Management",
      description:
        "Manage Phaser's scene stack as components. Includes dedicated Preload, Overlay, and more.",
    },
    {
      title: "TypeScript First",
      description:
        "Full type definitions with type-safe access to every Phaser GameObject property.",
    },
  ],
  ja: [
    {
      title: "宣言的なJSX",
      description:
        "PhaserのGameObjectをJSXで直接記述。仮想DOMなしで直接操作でき、プロパティの変更も宣言的に反映されます。",
    },
    {
      title: "きめ細かなリアクティビティ",
      description:
        "SolidJSのSignalでゲーム状態を管理できます。必要な箇所だけ更新可能で、不要な再レンダリングはありません。",
    },
    {
      title: "段階的な公開API",
      description:
        "L0(JSX) → L1(hooks) → L2(resources) → L3(frame) → L4(raw Phaser)。必要に応じて低レベルのAPIに段階的にアクセスできます。",
    },
    {
      title: "豊富なHooksとBehaviors",
      description:
        "useTween・useSpring・useStateMachineなどのHooksと、Spring・Oscillateなどの宣言的なBehaviorが提供されています。",
    },
    {
      title: "シーン管理",
      description:
        "Phaserのシーンスタックをコンポーネントとして管理。Preload・Overlayなどの専用コンポーネントが用意されています。",
    },
    {
      title: "TypeScriptファースト",
      description:
        "すべてのPhaser GameObjectプロパティに型安全にアクセスできる完全な型定義が提供されています。",
    },
  ],
};

const features = i18n[locale] ?? i18n.en;
---

<div class="features not-content">
  {
    features.map((f) => (
      <div class="feature-card">
        <h3>{f.title}</h3>
        <p>{f.description}</p>
      </div>
    ))
  }
</div>
