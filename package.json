    "@vitest/coverage-v8": "^4.1.0",
    "babel-preset-solid": "^1.9.10",
    "jsdom": "^29.0.1",
    "@playwright/test": "1.56.1",
    "playwright": "1.56.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
